{
  "name": "@bniddam-labs/medias-manager-nestjs",
  "version": "4.3.0",
  "description": "A NestJS module for handling media storage, retrieval, and on-demand image resizing with S3/MinIO backend",
  "author": "Benjamin Niddam",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "nestjs",
    "medias",
    "images",
    "s3",
    "minio",
    "resize",
    "sharp",
    "storage",
    "module"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bniddam-labs/medias-manager-nestjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "biome format --write src/",
    "format:check": "biome format src/",
    "lint": "biome lint --write src/",
    "lint:check": "biome lint src/",
    "check": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "test:cov": "jest --coverage --passWithNoTests",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "fluent-ffmpeg": "^2.1.3",
    "nestjs-minio-client": "^2.2.0",
    "nestjs-zod": "^5.2.1",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "reflect-metadata": "^0.1.0 || ^0.2.0",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@nestjs/cli": "^11.0.17",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/schematics": "^11.0.10",
    "@nestjs/testing": "^11.1.17",
    "@types/express": "^5.0.6",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.0.0",
    "@types/supertest": "^7.0.0",
    "jest": "^30.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
